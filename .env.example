# ==========================================================================
# VoiceForge AI — environment variables
# Copy to .env at the repo root. Both apps read from this file via dotenv.
# ==========================================================================

# ---- Runtime mode ---------------------------------------------------------
NODE_ENV=development

# ---- API server -----------------------------------------------------------
API_PORT=4000
WEB_PORT=3000

# ---- Frontend -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ---- Internal API (shared secret between Next.js and NestJS) ---------------
INTERNAL_API_KEY=your-random-secret-at-least-32-chars-here
INTERNAL_API_URL=http://localhost:4000

# ---- Supabase Postgres ----------------------------------------------------
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase Storage -----------------------------------------------------
SUPABASE_STORAGE_BUCKET=voiceforge

# ---- Valkey / Redis -------------------------------------------------------
REDIS_URL=

# ---- Voice providers ------------------------------------------------------
# Choose: vapi | retell | mock
VOICE_PROVIDER=mock
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_PHONE_NUMBER_ID=
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# ---- LLM ------------------------------------------------------------------
# Choose: openai | github | anthropic | azure-aifoundry | mock | local
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
GITHUB_TOKEN=
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_VERSION=2024-02-01

# ---- Embeddings -----------------------------------------------------------
EMBEDDING_PROVIDER=openai

# ---- Billing --------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ---- Email ----------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=VoiceForge <noreply@voiceforge.ai>
WEB_BASE_URL=http://localhost:3000

# ---- Google OAuth ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Security -------------------------------------------------------------
ENCRYPTION_KEY=
JWT_SECRET=change-me-in-production
DEFAULT_COUNTRY=US

# ---- Rate limiting --------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- Observability --------------------------------------------------------
METRICS_SCRAPE_TOKEN=
VOICE_WEBHOOK_SECRET=