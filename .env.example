# ==========================================================================
# VoiceForge AI — environment variables
# Copy to .env at the repo root. Both apps read from this file via dotenv.
# Mock providers have been REMOVED — only real providers are supported.
# ==========================================================================

# ---- Runtime mode ---------------------------------------------------------
NODE_ENV=development

# ---- API server -----------------------------------------------------------
API_PORT=4000
WEB_PORT=3000

# ---- Frontend -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional: route Clerk hosted UI to custom paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- Supabase Postgres ----------------------------------------------------
# Pooled connection (port 6543) — used at runtime.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (port 5432) — used by Prisma for migrate / db push.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase Storage -----------------------------------------------------
SUPABASE_STORAGE_BUCKET=voiceforge

# ---- Valkey / Redis (AWS ElastiCache Serverless, Upstash, Redis Cloud) ----
# Leave empty to fall back to an in-process queue stub (safe for local dev).
REDIS_URL=

# ---- Authentication (Clerk only — mock auth removed) ----------------------
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ---- Voice providers (mock removed — pick one and set its key) ------------
VOICE_PROVIDER=vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# ---- LLM providers (mock removed) -----------------------------------------
#   LLM_PROVIDER=openai       → OPENAI_API_KEY against api.openai.com (default: gpt-4o-mini)
#   LLM_PROVIDER=github       → GITHUB_TOKEN with models:read scope against models.github.ai
#   LLM_PROVIDER=azure-aifoundry → LLM_API_KEY + LLM_BASE_URL (Azure AI Foundry endpoint)
#   LLM_PROVIDER=local        → deterministic template merge (no API key needed)
LLM_PROVIDER=local
OPENAI_API_KEY=
GITHUB_TOKEN=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_VERSION=2024-02-01

ANTHROPIC_API_KEY=

# ---- Embeddings (OpenAI only — mock removed) ------------------------------
EMBEDDING_PROVIDER=openai

# ---- Security -------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
JWT_SECRET=change-me-in-production

# ---- Stripe ---------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ---- Google OAuth ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Rate limiting --------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- Observability --------------------------------------------------------
METRICS_SCRAPE_TOKEN=
VOICE_WEBHOOK_SECRET=
