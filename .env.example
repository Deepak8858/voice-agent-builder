# ==========================================================================
# VoiceForge AI \u2014 environment variables
# Copy to .env at the repo root. Both apps read from this file via dotenv.
# ==========================================================================

# ---- Runtime mode ---------------------------------------------------------
NODE_ENV=development

# ---- API server -----------------------------------------------------------
API_PORT=4000
WEB_PORT=3000

# ---- Frontend -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional: route Clerk hosted UI to custom paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- Supabase Postgres ----------------------------------------------------
# Pooled connection (port 6543) \u2014 used at runtime.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (port 5432) \u2014 used by Prisma for migrate / db push.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ---- Valkey / Redis (AWS ElastiCache Serverless, Upstash, Redis Cloud) ----
# Leave empty to fall back to an in-process queue stub (safe for local dev).
#
# AWS ElastiCache Serverless Valkey REQUIRES TLS (use `rediss://`) and lives
# inside a VPC — production API must run in the same VPC (ECS/Fargate/Lambda
# or an EC2 in the subnet), otherwise the endpoint is not reachable.
#
# Template for this project's cache (fill in <password> if you set one):
#   REDIS_URL=rediss://:<password>@voice-6knamf.serverless.aps1.cache.amazonaws.com:6379
# No-password serverless cache:
#   REDIS_URL=rediss://voice-6knamf.serverless.aps1.cache.amazonaws.com:6379
REDIS_URL=

# ---- Provider switches (mock-first per docs/27_MOCK_BUILD_PLAN.md) --------
# Set to `clerk` once NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY and CLERK_SECRET_KEY are filled in.
AUTH_PROVIDER=mock
VOICE_PROVIDER=mock
LLM_PROVIDER=mock

# ---- Security -------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
JWT_SECRET=change-me-in-production

# ---- External providers (optional until Phase 3+) -------------------------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# LLM provider keys.
#   LLM_PROVIDER=openai → OPENAI_API_KEY against api.openai.com (default model: gpt-4o-mini)
#   LLM_PROVIDER=github → GITHUB_TOKEN with `models:read` scope against models.github.ai
#                         (default model: openai/gpt-4o-mini; catalog: github.com/marketplace/models)
#   LLM_PROVIDER=mock   → no network, deterministic template merge
# LLM_BASE_URL is only needed if you want to override the provider's default endpoint
# (e.g. point OpenAI-compatible adapters at a self-hosted gateway).
OPENAI_API_KEY=
GITHUB_TOKEN=

# Knowledge embedding provider:
#   EMBEDDING_PROVIDER=mock   → deterministic 64-dim hash embeddings (default; no network)
#   EMBEDDING_PROVIDER=openai → text-embedding-3-small via api.openai.com (needs OPENAI_API_KEY)
EMBEDDING_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

ANTHROPIC_API_KEY=
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
