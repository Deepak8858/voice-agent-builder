# =============================================================================
# VoiceForge AI — API Container (NestJS)
# =============================================================================
# Build context: repository root (required for npm workspaces / monorepo).
# ---------------------------------------------------------------------------

FROM --platform=linux/amd64 node:20-slim AS builder
WORKDIR /app

# Install build dependencies (native modules may need python3/make)
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

# Copy workspace manifests first for layer caching
COPY package*.json ./
COPY apps/api/package*.json ./apps/api/
COPY packages/shared/package*.json ./packages/shared/
COPY packages/ui/package*.json ./packages/ui/

# Install monorepo dependencies (respects workspaces)
RUN npm install

# Copy source
COPY apps/api ./apps/api
COPY packages/shared ./packages/shared
COPY packages/ui ./packages/ui
COPY tsconfig.base.json ./

# Generate Prisma client before building (if schema exists)
RUN if [ -f apps/api/prisma/schema.prisma ]; then npx prisma generate --schema=apps/api/prisma/schema.prisma; fi

# Build shared packages then API
RUN npm run build -w @voiceforge/shared
RUN npm run build -w @voiceforge/api

# =============================================================================
# Production stage
# =============================================================================
FROM --platform=linux/amd64 node:20-slim AS production

WORKDIR /app
ENV NODE_ENV=production

# Add tini for proper signal handling + openssl for Prisma runtime
RUN apt-get update && \
    apt-get install -y --no-install-recommends tini openssl && \
    rm -rf /var/lib/apt/lists/* && \
    groupadd -g 1001 nodegroup && \
    useradd -u 1001 -g nodegroup nodeuser && \
    chown -R nodeuser:nodegroup /app

# Copy package manifests and install production deps only
COPY --chown=nodeuser:nodegroup package*.json ./
COPY --chown=nodeuser:nodegroup apps/api/package*.json ./apps/api/
COPY --chown=nodeuser:nodegroup packages/shared/package*.json ./packages/shared/
COPY --chown=nodeuser:nodegroup packages/ui/package*.json ./packages/ui/
RUN npm install --ignore-scripts --omit=dev

# Copy built artifacts (owned by nodeuser)
COPY --chown=nodeuser:nodegroup --from=builder /app/apps/api/dist ./apps/api/dist
COPY --chown=nodeuser:nodegroup --from=builder /app/apps/api/prisma ./apps/api/prisma
COPY --chown=nodeuser:nodegroup --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --chown=nodeuser:nodegroup --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --chown=nodeuser:nodegroup --from=builder /app/node_modules/prisma ./node_modules/prisma
COPY --chown=nodeuser:nodegroup --from=builder /app/node_modules/@prisma ./node_modules/@prisma

# Switch to non-root user
USER nodeuser

# Health-check endpoint (NestJS default)
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:4000/api/v1/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"

EXPOSE 4000

# Use tini as init system to properly handle SIGTERM and forward to Node.js
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "apps/api/dist/main.js"]
