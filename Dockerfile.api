# =============================================================================
# VoiceForge AI — API Container (NestJS)
# =============================================================================
# Build context: repository root (required for npm workspaces / monorepo).
# ---------------------------------------------------------------------------

FROM node:20-alpine AS builder
WORKDIR /app

# Install build dependencies (native modules may need python3/make)
RUN apk add --no-cache python3 make g++

# Copy workspace manifests first for layer caching
COPY package*.json ./
COPY apps/api/package*.json ./apps/api/
COPY packages/shared/package*.json ./packages/shared/
COPY packages/ui/package*.json ./packages/ui/

# Install monorepo dependencies (respects workspaces)
RUN npm ci --ignore-scripts

# Copy source
COPY apps/api ./apps/api
COPY packages/shared ./packages/shared
COPY packages/ui ./packages/ui
COPY tsconfig.base.json ./

# Generate Prisma client before building
RUN npx prisma generate --schema=apps/api/prisma/schema.prisma

# Build shared packages then API
RUN npm run build -w @voiceforge/shared
RUN npm run build -w @voiceforge/api

# =============================================================================
# Production stage
# =============================================================================
FROM node:20-alpine AS production
WORKDIR /app
ENV NODE_ENV=production

# Copy package manifests and install production deps only
COPY package*.json ./
COPY apps/api/package*.json ./apps/api/
COPY packages/shared/package*.json ./packages/shared/
COPY packages/ui/package*.json ./packages/ui/
RUN npm ci --ignore-scripts --omit=dev

# Copy built artifacts
COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/apps/api/prisma ./apps/api/prisma
COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma

# Health-check endpoint (NestJS default)
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:4000/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"

EXPOSE 4000
CMD ["node", "apps/api/dist/main.js"]
