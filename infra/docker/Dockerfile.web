# =============================================================================
# VoiceForge AI — Web Container (Next.js standalone)
# =============================================================================
# Build context: repository root (monorepo)
# Build args: NEXT_PUBLIC_* vars for build-time injection
# ---------------------------------------------------------------------------

FROM --platform=linux/amd64 node:20-alpine AS builder
WORKDIR /app

# Build arguments for environment injection at build time
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}
ENV NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
ENV NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=${NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY}
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}

# Copy workspace manifests first for layer caching
COPY package*.json ./
COPY pnpm-workspace.yaml ./
COPY apps/web/package*.json ./apps/web/
COPY packages/shared/package*.json ./packages/shared/
COPY packages/ui/package*.json ./packages/ui/

# Copy package source so file: references work
COPY packages/shared ./packages/shared
COPY packages/ui ./packages/ui

# Replace pnpm workspace:* with npm-compatible file: paths
RUN sed -i 's|"workspace:\*"|"file:./packages/shared"|g' apps/web/package.json && \
    sed -i 's|"workspace:\*"|"file:./packages/ui"|g' apps/web/package.json 2>/dev/null || true

# Remove Windows-generated lock files and install fresh for Linux
RUN rm -f package-lock.json pnpm-lock.yaml
RUN npm install --ignore-scripts --no-audit --no-fund

# Copy source
COPY apps/web ./apps/web
COPY packages/shared ./packages/shared
COPY packages/ui ./packages/ui
COPY tsconfig.base.json ./

# Build shared packages then web
RUN npm run build -w @voiceforge/shared
RUN npm run build -w @voiceforge/web

# =============================================================================
# Production stage — minimal standalone runner
# =============================================================================
FROM --platform=linux/amd64 node:20-alpine AS production

WORKDIR /app
ENV NODE_ENV=production

RUN apk add --no-cache tini \
    && addgroup -g 1001 nodegroup \
    && adduser -u 1001 -G nodegroup -s /bin/sh -D nodeuser \
    && chown -R nodeuser:nodegroup /app

ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Copy ALL node_modules from builder (includes all monorepo deps, no npm ci needed)
COPY --chown=1001:1001 --from=builder /app/node_modules ./

# Copy standalone output from builder
COPY --chown=1001:1001 --from=builder /app/apps/web/.next/standalone ./
COPY --chown=1001:1001 --from=builder /app/apps/web/.next/static ./static
COPY --chown=1001:1001 --from=builder /app/apps/web/public ./public

USER nodeuser

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD node -e "require('http').get('http://127.0.0.1:' + (process.env.PORT || 3000) + '/api/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "server.js"]