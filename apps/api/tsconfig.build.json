{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noEmitOnError": false,
    "strict": false,
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "paths": {
      "@voiceforge/shared": ["../../packages/shared/dist/index.d.ts"],
      "@voiceforge/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "prisma/seed.ts"]
}
