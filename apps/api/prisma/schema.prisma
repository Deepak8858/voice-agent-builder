// VoiceForge AI — Prisma schema
// Phase 2: Multi-tenant RLS alignment. Every customer-owned table has organization_id.
// New tables: AppOrgMembership (Clerk role cache), WorkspaceMembership (client access).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --------------------------------------------------------------------------
// Tenancy core
// --------------------------------------------------------------------------

model User {
  id              String       @id @default(uuid()) @db.Uuid
  externalAuthId  String?      @unique @map("external_auth_id")
  email           String       @unique
  name            String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  ownedOrganizations Organization[]    @relation("OrganizationOwner")
  memberships        Membership[]
  appOrgMemberships  AppOrgMembership[]
  workspaceMemberships WorkspaceMembership[]
  auditLogs          AuditLog[]
  createdAgents      Agent[]           @relation("AgentCreatedBy")
  createdVersions    AgentVersion[]    @relation("AgentVersionCreatedBy")
  createdKnowledge   KnowledgeSource[] @relation("KnowledgeSourceCreatedBy")

  @@map("users")
}

model Organization {
  id            String   @id @default(uuid()) @db.Uuid
  clerkOrgId    String?  @unique @map("clerk_org_id")
  name          String
  slug          String   @unique
  ownerUserId   String   @map("owner_user_id") @db.Uuid
  plan          String   @default("free")
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner        User             @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  workspaces   Workspace[]
  subscriptions Subscription[]
  usageRecords UsageRecord[]
  appOrgMemberships AppOrgMembership[]
  agents       Agent[]

  @@index([ownerUserId])
  @@index([clerkOrgId])
  @@map("organizations")
}

model Workspace {
  id                 String     @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  parentWorkspaceId  String?    @map("parent_workspace_id") @db.Uuid
  type               String     @default("direct") // agency | client | direct
  name               String
  slug               String
  status             String     @default("active")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  parent        Workspace?    @relation("WorkspaceParent", fields: [parentWorkspaceId], references: [id])
  children      Workspace[]   @relation("WorkspaceParent")
  memberships   Membership[]
  workspaceMemberships WorkspaceMembership[]
  agents        Agent[]
  templates     AgentTemplate[]
  auditLogs     AuditLog[]
  knowledgeSources KnowledgeSource[]
  knowledgeChunks  KnowledgeChunk[]
  calls            Call[]
  callEvents       CallEvent[]
  callEvaluations  CallEvaluation[]
  tools            IntegrationTool[]
  toolInvocations  ToolInvocation[]
  contacts         Contact[]
  consentRecords   ConsentRecord[]
  dncEntries       DncEntry[]
  complianceChecks ComplianceCheck[]
  analyticsEvents  AnalyticsEvent[]
  whiteLabel       WhiteLabelSettings?
  clientInvites    ClientInvite[]    @relation("InviteAgency")
  invitesAccepted  ClientInvite[]    @relation("InviteClient")
  usageRecords     UsageRecord[]
  googleCalendarConfig GoogleCalendarConfig?

  @@unique([organizationId, slug])
  @@index([parentWorkspaceId])
  @@map("workspaces")
}

model Membership {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  role         String    @default("owner") // owner | admin | editor | viewer
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id])
  workspace  Workspace  @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// Clerk org membership cache for RLS and backend joins
model AppOrgMembership {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  clerkUserId    String    @map("clerk_user_id")
  clerkOrgId     String    @map("clerk_org_id")
  role           String    // owner | admin | member | viewer
  permissions    String[]  @default([])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([clerkUserId])
  @@index([clerkOrgId])
  @@map("app_org_memberships")
}

// Workspace-level access for client users (agency model)
model WorkspaceMembership {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  clerkUserId String    @map("clerk_user_id")
  role        String    // owner | admin | member | viewer
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, clerkUserId])
  @@index([clerkUserId])
  @@map("workspace_memberships")
}

// --------------------------------------------------------------------------
// Agent builder
// --------------------------------------------------------------------------

model Agent {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  name            String
  description     String?
  industry        String
  agentType       String    @map("agent_type")
  status          String    @default("draft") // draft | published | paused | archived
  specJson        Json?     @map("spec_json")
  activeVersionId String?   @map("active_version_id") @db.Uuid
  createdBy       String?   @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace         Workspace       @relation(fields: [workspaceId], references: [id])
  organization      Organization?   @relation(fields: [organizationId], references: [id])
  creator           User?           @relation("AgentCreatedBy", fields: [createdBy], references: [id])
  versions          AgentVersion[]
  knowledgeSources  KnowledgeSource[]
  knowledgeChunks   KnowledgeChunk[]
  calls             Call[]
  evaluations       CallEvaluation[]
  tools             IntegrationTool[]
  toolInvocations   ToolInvocation[]
  complianceChecks  ComplianceCheck[]
  analyticsEvents   AnalyticsEvent[]

  @@index([workspaceId])
  @@index([organizationId])
  @@index([createdBy])
  @@map("agents")
}

model AgentVersion {
  id                  String   @id @default(uuid()) @db.Uuid
  agentId             String   @map("agent_id") @db.Uuid
  organizationId      String?   @map("organization_id") @db.Uuid
  versionNumber       Int      @map("version_number")
  specJson            Json     @map("spec_json")
  provider            String?
  providerRuntimeId   String?  @map("provider_runtime_id")
  deploymentStatus    String   @default("not_deployed") @map("deployment_status")
  note                String?
  createdBy           String?  @map("created_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  agent       Agent   @relation(fields: [agentId], references: [id])
  creator     User?   @relation("AgentVersionCreatedBy", fields: [createdBy], references: [id])

  @@unique([agentId, versionNumber])
  @@index([organizationId])
  @@index([createdBy])
  @@map("agent_versions")
}

model AgentTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String?  @map("workspace_id") @db.Uuid
  organizationId  String?  @map("organization_id") @db.Uuid
  name            String
  slug            String   @unique
  industry        String
  agentType       String   @map("agent_type")
  description     String
  templateSpec    Json     @map("template_spec")
  isPublic        Boolean  @default(true) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace  Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([organizationId])
  @@map("agent_templates")
}

// --------------------------------------------------------------------------
// Knowledge (Phase 2)
// --------------------------------------------------------------------------

model KnowledgeSource {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  agentId         String?  @map("agent_id") @db.Uuid
  sourceType      String   @map("source_type") // url | text | file
  title           String
  fileUrl         String?  @map("file_url")
  content         String?  // raw text for inline source; nullable for url/file
  status          String   @default("pending") // pending | processing | ready | failed
  metadata        Json?
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace  Workspace        @relation(fields: [workspaceId], references: [id])
  agent      Agent?           @relation(fields: [agentId], references: [id])
  creator    User?            @relation("KnowledgeSourceCreatedBy", fields: [createdBy], references: [id])
  chunks     KnowledgeChunk[]

  @@index([workspaceId, agentId])
  @@index([organizationId])
  @@index([agentId])
  @@index([createdBy])
  @@map("knowledge_sources")
}

model KnowledgeChunk {
  id              String   @id @default(uuid()) @db.Uuid
  sourceId        String   @map("source_id") @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  agentId         String?  @map("agent_id") @db.Uuid
  chunkIndex      Int      @map("chunk_index")
  content         String
  embedding       Unsupported("vector(1536)")? // pgvector for semantic search
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  source     KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  workspace  Workspace       @relation(fields: [workspaceId], references: [id])
  agent      Agent?          @relation(fields: [agentId], references: [id])

  @@index([sourceId, chunkIndex])
  @@index([workspaceId, agentId])
  @@index([organizationId])
  @@index([agentId])
  @@map("knowledge_chunks")
}

// --------------------------------------------------------------------------
// Calls (Phase 3)
// --------------------------------------------------------------------------

model Call {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @map("workspace_id") @db.Uuid
  organizationId    String?   @map("organization_id") @db.Uuid
  agentId           String   @map("agent_id") @db.Uuid
  agentVersionId    String?  @map("agent_version_id") @db.Uuid
  contactId         String?  @map("contact_id") @db.Uuid
  direction         String   // inbound | outbound | browser_test
  status            String   @default("queued") // queued | ringing | in_progress | completed | failed | cancelled
  provider          String   @default("")
  providerCallId    String?  @map("provider_call_id")
  fromNumber        String?  @map("from_number")
  toNumber          String?  @map("to_number")
  contactName       String?  @map("contact_name")
  startedAt         DateTime? @map("started_at")
  endedAt           DateTime? @map("ended_at")
  durationSeconds   Int?     @map("duration_seconds")
  recordingUrl      String?  @map("recording_url")
  transcriptText    String?  @map("transcript_text")
  outcome           String?
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  workspace        Workspace        @relation(fields: [workspaceId], references: [id])
  agent            Agent            @relation(fields: [agentId], references: [id])
  contact          Contact?         @relation(fields: [contactId], references: [id])
  events           CallEvent[]
  evaluation       CallEvaluation?
  toolInvocations  ToolInvocation[]
  complianceChecks ComplianceCheck[]
  analyticsEvents  AnalyticsEvent[]

  @@index([workspaceId, createdAt])
  @@index([organizationId])
  @@index([agentId, createdAt])
  @@index([contactId])
  @@map("calls")
}

model CallEvent {
  id             String   @id @default(uuid()) @db.Uuid
  callId         String   @map("call_id") @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  eventType      String   @map("event_type")
  eventTime      DateTime @default(now()) @map("event_time")
  payload        Json?

  call       Call       @relation(fields: [callId], references: [id], onDelete: Cascade)
  workspace  Workspace  @relation(fields: [workspaceId], references: [id])

  @@index([callId, eventTime])
  @@index([workspaceId])
  @@index([organizationId])
  @@map("call_events")
}

model CallEvaluation {
  id             String   @id @default(uuid()) @db.Uuid
  callId         String   @unique @map("call_id") @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  agentId        String   @map("agent_id") @db.Uuid
  agentVersionId String?  @map("agent_version_id") @db.Uuid
  overallScore   Float    @map("overall_score")
  metricScores   Json     @map("metric_scores") // [{ name, score, reason }]
  summary        String?
  evaluatedBy    String   @default("rule_based") @map("evaluated_by") // rule_based | llm | manual
  createdAt      DateTime @default(now()) @map("created_at")

  call       Call       @relation(fields: [callId], references: [id], onDelete: Cascade)
  workspace  Workspace  @relation(fields: [workspaceId], references: [id])
  agent      Agent      @relation(fields: [agentId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([organizationId])
  @@index([agentId, createdAt])
  @@map("call_evaluations")
}

// --------------------------------------------------------------------------
// Audit
// --------------------------------------------------------------------------

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  metadata       Json?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  actor       User?      @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([organizationId])
  @@index([actorUserId])
  @@map("audit_logs")
}

// --------------------------------------------------------------------------
// Integrations / tools (Phase 5)
// --------------------------------------------------------------------------

model IntegrationTool {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  agentId        String?  @map("agent_id") @db.Uuid
  name           String
  description    String
  toolType       String   @map("tool_type") // webhook | google_calendar | http_get | http_post
  config         Json     // { url, method, headers, hmac_secret_ref, ... }
  inputSchema    Json     @map("input_schema") // JSON Schema for expected args
  enabled        Boolean  @default(true)
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace    Workspace        @relation(fields: [workspaceId], references: [id])
  agent        Agent?           @relation(fields: [agentId], references: [id])
  invocations  ToolInvocation[]

  @@unique([workspaceId, name])
  @@index([workspaceId, agentId])
  @@index([organizationId])
  @@index([agentId])
  @@map("integration_tools")
}

model ToolInvocation {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  toolId          String   @map("tool_id") @db.Uuid
  agentId         String?  @map("agent_id") @db.Uuid
  callId          String?  @map("call_id") @db.Uuid
  status          String   @default("pending") // pending | success | failed
  requestPayload  Json     @map("request_payload")
  responseStatus  Int?     @map("response_status")
  responseBody    Json?    @map("response_body")
  errorMessage    String?  @map("error_message")
  durationMs      Int?     @map("duration_ms")
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")

  workspace  Workspace       @relation(fields: [workspaceId], references: [id])
  tool       IntegrationTool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  agent      Agent?          @relation(fields: [agentId], references: [id])
  call       Call?           @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([workspaceId, startedAt])
  @@index([organizationId])
  @@index([toolId, startedAt])
  @@index([agentId])
  @@index([callId])
  @@map("tool_invocations")
}

// --------------------------------------------------------------------------
// Compliance (Phase 6)
// --------------------------------------------------------------------------

model Contact {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  phone          String
  email          String?
  fullName       String?  @map("full_name")
  metadata       Json?
  optOut         Boolean  @default(false) @map("opt_out")
  optOutReason   String?  @map("opt_out_reason")
  optOutAt       DateTime? @map("opt_out_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace      Workspace        @relation(fields: [workspaceId], references: [id])
  consentRecords ConsentRecord[]
  calls          Call[]

  @@unique([workspaceId, phone])
  @@index([organizationId])
  @@index([workspaceId, optOut])
  @@map("contacts")
}

model ConsentRecord {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  contactId      String    @map("contact_id") @db.Uuid
  consentType    String    @map("consent_type") // outbound_marketing | outbound_transactional | recording | ai_disclosure
  source         String    // web_form | imported | verbal | api | other
  proofUrl       String?   @map("proof_url")
  consentedAt    DateTime  @default(now()) @map("consented_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId, contactId])
  @@index([organizationId])
  @@index([contactId, consentType])
  @@map("consent_records")
}

model DncEntry {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  phone          String
  source         String   @default("manual") // manual | imported | request | regulator
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, phone])
  @@index([organizationId])
  @@index([workspaceId, createdAt])
  @@map("dnc_entries")
}

model ComplianceCheck {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  agentId        String   @map("agent_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  callId         String?  @map("call_id") @db.Uuid
  direction      String   // inbound | outbound | browser_test
  status         String   // passed | blocked
  reasons        Json     // ComplianceReason[]: [{ code, message, severity }]
  metadata       Json?
  checkedAt      DateTime @default(now()) @map("checked_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  agent      Agent     @relation(fields: [agentId], references: [id])
  call       Call?     @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([workspaceId, checkedAt])
  @@index([organizationId])
  @@index([agentId, checkedAt])
  @@index([callId])
  @@map("compliance_checks")
}

// --------------------------------------------------------------------------
// Analytics (Phase 7)
// --------------------------------------------------------------------------

model AnalyticsEvent {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  agentId        String?  @map("agent_id") @db.Uuid
  callId         String?  @map("call_id") @db.Uuid
  eventType      String   @map("event_type") // call.started | call.ended | call.blocked | appointment.booked | lead.qualified | tool.failed | ...
  payload        Json?
  occurredAt     DateTime @default(now()) @map("occurred_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  agent      Agent?    @relation(fields: [agentId], references: [id])
  call       Call?     @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([workspaceId, eventType, occurredAt])
  @@index([organizationId])
  @@index([agentId, occurredAt])
  @@index([callId])
  @@map("analytics_events")
}

// --------------------------------------------------------------------------
// White Label (Phase 8)
// --------------------------------------------------------------------------

model WhiteLabelSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  workspaceId           String   @unique @map("workspace_id") @db.Uuid
  brandName             String?  @map("brand_name")
  logoUrl               String?  @map("logo_url")
  primaryColor          String?  @map("primary_color")
  customDomain          String?  @unique @map("custom_domain")
  supportEmail          String?  @map("support_email")
  hidePlatformBranding  Boolean  @default(false) @map("hide_platform_branding")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("white_label_settings")
}

model ClientInvite {
  id                String   @id @default(uuid()) @db.Uuid
  agencyWorkspaceId String   @map("agency_workspace_id") @db.Uuid
  clientWorkspaceId String?  @map("client_workspace_id") @db.Uuid
  email             String
  role              String   @default("admin") // admin | viewer
  token             String   @unique
  status            String   @default("pending") // pending | accepted | revoked | expired
  expiresAt         DateTime @map("expires_at")
  invitedBy         String?  @map("invited_by") @db.Uuid
  acceptedAt        DateTime? @map("accepted_at")
  createdAt         DateTime @default(now()) @map("created_at")

  agencyWorkspace  Workspace  @relation("InviteAgency", fields: [agencyWorkspaceId], references: [id], onDelete: Cascade)
  clientWorkspace  Workspace? @relation("InviteClient", fields: [clientWorkspaceId], references: [id], onDelete: SetNull)

  @@index([agencyWorkspaceId, status])
  @@index([email])
  @@map("client_invites")
}

// --------------------------------------------------------------------------
// Billing (Phase 9)
// --------------------------------------------------------------------------

model Subscription {
  id                    String    @id @default(uuid()) @db.Uuid
  organizationId        String    @unique @map("organization_id") @db.Uuid
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  plan                  String    @default("free") // free | starter | growth | enterprise
  status                String    @default("active") // active | trialing | past_due | canceled
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime? @map("trial_end")
  stripeMetadata       Json?     @map("stripe_metadata")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model UsageRecord {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  billableMetric  String   @map("billable_metric") // calls | minutes | tools | agents
  quantity        Int      @map("quantity")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId, billableMetric, periodStart])
  @@index([workspaceId, billableMetric, periodStart])
  @@map("usage_records")
}

model StripeEvent {
  id                String    @id @default(uuid()) @db.Uuid
  stripeEventId     String    @unique @map("stripe_event_id")
  type              String
  apiVersion        String?   @map("api_version")
  created           DateTime
  data              Json      @map("data")
  livemode          Boolean   @default(false) @map("livemode")
  pendingWebhooks   Int       @default(0) @map("pending_webhooks")
  requestContext    Json?     @map("request_context")
  processedAt       DateTime? @map("processed_at")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([stripeEventId])
  @@index([type, created])
  @@map("stripe_events")
}

model WebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  provider        String
  providerEventId String    @map("provider_event_id")
  eventType       String    @map("event_type")
  payload         Json
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([provider, providerEventId])
  @@index([provider, eventType])
  @@index([processedAt])
  @@map("webhook_events")
}

model GoogleCalendarConfig {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @unique @map("workspace_id") @db.Uuid
  accessToken   String   @map("access_token")
  refreshToken  String   @map("refresh_token")
  tokenExpiry   DateTime @map("token_expiry")
  calendarId    String   @default("primary") @map("calendar_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("google_calendar_configs")
}
