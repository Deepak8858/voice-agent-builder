# =============================================================================
# VoiceForge AI — Production Environment Variables Template
# =============================================================================
# Copy this to /opt/voiceforge/.env on the EC2 instance.
# Replace every <...> placeholder with real values.
# =============================================================================

# ---- Runtime ---------------------------------------------------------------
NODE_ENV=production
API_PORT=4000
WEB_PORT=3000

# ---- Supabase Auth --------------------------------------------------------
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# sb_publishable_... key (safe for frontend)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<sb_publishable_xxx>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sb_publishable_xxx>

# ---- Supabase Postgres ----------------------------------------------------
# Pooled (PgBouncer, port 6543) — for runtime:
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct (port 5432) — for Prisma migrations:
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
# From: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
# From: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=<jwt_secret>

# ---- Redis ----------------------------------------------------------------
# From: AWS ElastiCache / Upstash / Redis Cloud
REDIS_URL=redis://default:<password>@<host>:<port>

# ---- Auth -----------------------------------------------------------------
AUTH_PROVIDER=supabase

# ---- Frontend URLs -------------------------------------------------------
# Public URLs (used by nginx redirects, Stripe callbacks, etc.)
NEXT_PUBLIC_API_URL=https://<your-domain>/api/v1
NEXT_PUBLIC_APP_URL=https://<your-domain>

# Internal URL the API uses to reach itself / web
WEB_BASE_URL=https://<your-domain>

# Allowed CORS origins (comma-separated, no trailing comma)
ALLOWED_ORIGINS=https://<your-domain>

# ---- Security -------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<64-char-hex-string>
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-char-hex-string>
# Shared secret: frontend uses this to call API endpoints that bypass Supabase JWT
INTERNAL_API_KEY=<32+ char random string>

# ---- Providers -----------------------------------------------------------
VOICE_PROVIDER=vapi          # vapi | twilio
LLM_PROVIDER=anthropic       # github | openai | anthropic | azure-aifoundry
EMBEDDING_PROVIDER=openai

# ---- Vapi (Voice) -------------------------------------------------------
# From: https://dashboard.vapi.ai → Account → API Key
VAPI_API_KEY=<vapi-api-key>
VAPI_BASE_URL=https://api.vapi.ai
# From: https://dashboard.vapi.ai → Account → Webhook Secret
VAPI_WEBHOOK_SECRET=<vapi-webhook-secret>
VAPI_PHONE_NUMBER_ID=<optional-default-phone-number-id>

# ---- Twilio (Voice) ------------------------------------------------------
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_PHONE_NUMBER_PREFIX=+1
# Optional Twilio SIP domain for SIP trunking
TWILIO_SIP_DOMAIN=<twilio-sip-domain>
# Webhook URLs for Twilio call events (point to your API)
TWILIO_TWIML_WEBHOOK_URL=https://<your-domain>/api/v1/voice/twilio/twiml
TWILIO_STATUS_WEBHOOK_URL=https://<your-domain>/api/v1/voice/twilio/status

# ---- Deepgram (STT/TTS) --------------------------------------------------
# From: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=<deepgram-api-key>
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_VOICE=aura-2-en-us

# ---- LLM Providers --------------------------------------------------------
# Generate at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-7-20250514

# Generate at https://platform.openai.com → API Keys
OPENAI_API_KEY=<openai-api-key>
LLM_MODEL=gpt-4o

# GitHub Models (if LLM_PROVIDER=github)
# Generate at https://github.com/settings/tokens (classic, scopes: read:org)
GITHUB_TOKEN=<github-personal-access-token>

# Azure AI Foundry
AZURE_AI_FOUNDRY_API_KEY=<azure-key>
AZURE_AI_FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com
AZURE_AI_FOUNDRY_DEPLOYMENT=<deployment-name>
LLM_API_VERSION=2024-06-01

# Base URL for custom/other LLM backends (e.g., local LM Studio, Groq)
LLM_BASE_URL=<optional-custom-llm-base-url>
LLM_API_KEY=<optional-custom-llm-key>

# ---- Email (Resend) ------------------------------------------------------
# From: https://resend.com → API Keys
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=noreply@<your-domain>

# ---- Storage (S3-compatible) ---------------------------------------------
# For call recordings, exported data
S3_BUCKET=<s3-bucket-name>
S3_REGION=<region>                        # e.g., ap-south-1
S3_ACCESS_KEY_ID=<s3-access-key>
S3_SECRET_ACCESS_KEY=<s3-secret-key>
# Or Cloudflare R2:
R2_BUCKET=<r2-bucket-name>
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>

# ---- ClickHouse (Analytics) ----------------------------------------------
# Optional: for call analytics and custom dashboards
CLICKHOUSE_URL=http://<clickhouse-host>:8123
CLICKHOUSE_USER=<clickhouse-user>
CLICKHOUSE_PASSWORD=<clickhouse-password>

# ---- Stripe Billing ------------------------------------------------------
# From: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_<...>
# From: https://dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_<...>
# From: Stripe Dashboard → Products → copy Price ID
STRIPE_STARTER_PRICE_ID=price_<...>
STRIPE_GROWTH_PRICE_ID=price_<...>
STRIPE_ENTERPRISE_PRICE_ID=price_<...>

# ---- Rate Limiting -------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- Observability -------------------------------------------------------
# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=https://<otlp-collector>:4318
OTEL_SERVICE_NAME=voiceforge-api
LOG_LEVEL=info

# Prometheus metrics scrape token (set by docker-compose.prod.yml)
METRICS_SCRAPE_TOKEN=<generate-with-openssl-rand-hex-32>

# Grafana admin password (set by docker-compose.prod.yml)
GRAFANA_ADMIN_PASSWORD=<strong-password>

# ---- Google OAuth (optional) ---------------------------------------------
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

# ---- Feature Flags ------------------------------------------------------
LLM_CACHE_TTL_SECONDS=86400