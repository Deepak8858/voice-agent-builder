{
  "name": "voiceforge-ai",
  "version": "0.1.0",
  "private": true,
  "description": "VoiceForge AI — Lovable-style AI voice calling agent builder (monorepo).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm:dev -w @voiceforge/api\" \"npm:dev -w @voiceforge/web\"",
    "build": "npm run build -w @voiceforge/shared && npm run build -w @voiceforge/api && npm run build -w @voiceforge/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate -w @voiceforge/api",
    "db:push": "npm run db:push -w @voiceforge/api",
    "db:seed": "npm run db:seed -w @voiceforge/api",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0"
  }
}
