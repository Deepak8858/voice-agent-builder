# =============================================================================
# VoiceForge AI — Web Container (Next.js standalone)
# =============================================================================
# Build context: repository root (required for npm workspaces / monorepo).
# ---------------------------------------------------------------------------

FROM --platform=linux/amd64 node:20-slim AS builder
WORKDIR /app

# Build arguments for environment injection at build time
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_CLERK_SIGN_IN_URL
ARG NEXT_PUBLIC_CLERK_SIGN_UP_URL
ARG NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL
ARG NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}
ENV NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY}
ENV NEXT_PUBLIC_CLERK_SIGN_IN_URL=${NEXT_PUBLIC_CLERK_SIGN_IN_URL}
ENV NEXT_PUBLIC_CLERK_SIGN_UP_URL=${NEXT_PUBLIC_CLERK_SIGN_UP_URL}
ENV NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=${NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL}
ENV NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=${NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL}

# Copy workspace manifests first for layer caching
COPY package*.json ./
COPY apps/web/package*.json ./apps/web/
COPY packages/shared/package*.json ./packages/shared/
COPY packages/ui/package*.json ./packages/ui/

# Work around npm optional-dependency bug #4828:
# package-lock.json generated on Windows omits Linux native binaries.
# Removing it forces fresh resolution inside the Linux container.
RUN rm -f package-lock.json
RUN npm install

# Copy source
COPY apps/web ./apps/web
COPY packages/shared ./packages/shared
COPY packages/ui ./packages/ui
COPY tsconfig.base.json ./

# Build shared packages then web
RUN npm run build -w @voiceforge/shared
RUN npm run build -w @voiceforge/web

# =============================================================================
# Production stage — minimal standalone runner
# =============================================================================
FROM --platform=linux/amd64 node:20-slim AS production

WORKDIR /app
ENV NODE_ENV=production

# Add tini for proper signal handling
RUN apt-get update && apt-get install -y --no-install-recommends tini && \
    rm -rf /var/lib/apt/lists/* && \
    groupadd -g 1001 nodegroup && \
    useradd -u 1001 -g nodegroup nodeuser && \
    chown -R nodeuser:nodegroup /app
ENV PORT=3000

# Copy standalone output from builder (owned by nodeuser)
COPY --chown=nodeuser:nodegroup --from=builder /app/apps/web/.next/standalone ./
COPY --chown=nodeuser:nodegroup --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --chown=nodeuser:nodegroup --from=builder /app/apps/web/public ./apps/web/public

# Switch to non-root user
USER nodeuser

EXPOSE 3000

# Health-check endpoint
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:' + (process.env.PORT || 3000) + '/api/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"

# Use tini as init system to properly handle SIGTERM and forward to Node.js
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "apps/web/server.js"]
